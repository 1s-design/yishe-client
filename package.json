{
  "name": "yishe-client",
  "version": "1.2.53",
  "description": "1s client",
  "main": "./generated/main/index.js",
  "author": "Jc",
  "homepage": "",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "clean:plugins": "node scripts/download-latest-plugins.mjs --clean",
    "prepare:plugins": "node scripts/download-latest-plugins.mjs",
    "prepare:plugins:win": "cross-env YISHE_PLUGIN_DOWNLOAD_PLATFORM=win32 node scripts/download-latest-plugins.mjs",
    "prepare:plugins:mac": "cross-env YISHE_PLUGIN_DOWNLOAD_PLATFORM=darwin node scripts/download-latest-plugins.mjs",
    "prepare:plugins:linux": "cross-env YISHE_PLUGIN_DOWNLOAD_PLATFORM=linux node scripts/download-latest-plugins.mjs",
    "prepare:remotion": "node scripts/prepare-remotion-binaries.mjs",
    "prepare:remotion:win": "cross-env YISHE_REMOTION_TARGET_PLATFORM=win32 YISHE_REMOTION_TARGET_ARCH=x64 node scripts/prepare-remotion-binaries.mjs",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": " electron-vite dev",
    "dev:win": "chcp 65001 && electron-vite dev",
    "build": " electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run prepare:plugins:win && npm run prepare:remotion:win && npm run build && cross-env ELECTRON_CACHE=.cache/electron ELECTRON_BUILDER_CACHE=.cache/electron-builder electron-builder --dir",
    "build:win": "npm run prepare:plugins:win && npm run prepare:remotion:win && npm run build && cross-env ELECTRON_CACHE=.cache/electron ELECTRON_BUILDER_CACHE=.cache/electron-builder electron-builder --win",
    "build:mac": "npm run prepare:plugins:mac && npm run prepare:remotion && npm run build && cross-env ELECTRON_CACHE=.cache/electron ELECTRON_BUILDER_CACHE=.cache/electron-builder electron-builder --mac",
    "build:linux": "npm run prepare:plugins:linux && npm run prepare:remotion && npm run build && cross-env ELECTRON_CACHE=.cache/electron ELECTRON_BUILDER_CACHE=.cache/electron-builder electron-builder --linux"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.434",
    "@remotion/renderer": "4.0.434",
    "@remotion/zod-types": "4.0.434",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@mdi/font": "^7.4.47",
    "@tailwindcss/postcss": "^4.1.17",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.22",
    "axios": "^1.10.0",
    "chalk": "^5.3.0",
    "cors": "^2.8.5",
    "cos-nodejs-sdk-v5": "^2.13.6",
    "delaunator": "^5.1.0",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.3.9",
    "element-plus": "^2.11.9",
    "express": "^5.1.0",
    "fs-extra": "^11.2.0",
    "mitt": "^3.0.1",
    "openai": "^4.104.0",
    "playwright-core": "^1.55.0",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.434",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^4.1.17",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/cors": "^2.8.19",
    "@types/node": "^22.14.1",
    "@types/react": "19.2.7",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-vue": "^5.2.3",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "eslint": "^9.24.0",
    "eslint-plugin-vue": "^10.0.0",
    "less": "^4.4.2",
    "prettier": "^3.5.3",
    "sass": "^1.85.1",
    "typescript": "^5.8.3",
    "vite": "^6.2.6",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^10.1.3",
    "vue-tsc": "^2.2.8"
  }
}
